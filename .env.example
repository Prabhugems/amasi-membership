# AMASI Membership Portal — environment variables
#
# Copy this file to .env.local for local dev. Don't commit .env.local.
# `NEXT_PUBLIC_*` keys are bundled into the browser; everything else is
# server-only (set on Vercel via `vercel env add`).
# `process.env.NODE_ENV` and `process.env.NEXT_RUNTIME` are framework-managed
# (do not set them yourself).

# ───── Supabase ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://jmdwxymbgxwdsmcwbahp.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-only. Bypasses RLS. Never expose to client.
SUPABASE_SERVICE_ROLE_KEY=

# ───── Auth / sessions ──────────────────────────────────────────────────────
# Used to sign admin + member JWTs and the public /v/<token> verify links.
# Min 32 chars. Rotate carefully — invalidates all sessions.
JWT_SECRET=

# ───── Default admin (env-managed super-admin, not in DB) ───────────────────
ADMIN_DEFAULT_EMAIL=admin@amasi.org
ADMIN_DEFAULT_PASSWORD=
# Where new ticket / urgent admin notifications go (falls back to default).
ADMIN_NOTIFICATION_EMAIL=
ADMIN_EMAIL=

# ───── Razorpay (membership fee + processing-fee Route split) ───────────────
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Razorpay-Route linked-account ID for Events360 (ILM processing fee split).
EVENTS360_RAZORPAY_ACCOUNT_ID=
# Optional override for the per-applicant processing fee in INR (default ₹100).
PROCESSING_FEE_INR=100

# ───── Email (Resend) ───────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL="AMASI <noreply@amasi.org>"

# ───── SMS / OTP (MSG91) ────────────────────────────────────────────────────
MSG91_AUTH_KEY=
MSG91_OTP_TEMPLATE_ID=
MSG91_TEMPLATE_ID=

# ───── WhatsApp (Gallabox) ──────────────────────────────────────────────────
GALLABOX_API_KEY=
GALLABOX_API_SECRET=
GALLABOX_CHANNEL_ID=

# ───── AI extraction / OCR ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=
# Fallback OCR provider when Claude Vision fails.
OCR_SPACE_API_KEY=

# ───── Airtable (FMAS / Master-FMAS sync) ───────────────────────────────────
# Personal Access Token. Required by scripts/seed-skill-courses.mjs and
# scripts/seed-fmas.ts. Not used by the live app at request time.
AIRTABLE_PAT=

# ───── Zoho Campaigns (member email-list sync) ──────────────────────────────
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REDIRECT_URI=
ZOHO_DEFAULT_LIST_KEY=

# ───── Apple / Google Wallet (membership card pass) ─────────────────────────
APPLE_WALLET_CERT=
APPLE_WALLET_KEY=
GOOGLE_WALLET_ISSUER_ID=
GOOGLE_WALLET_SERVICE_ACCOUNT_KEY=

# ───── Rate limiting / KV (Upstash Redis) ───────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Vercel KV-prefixed aliases (some routes still read these legacy names).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ───── Cron jobs ────────────────────────────────────────────────────────────
# Bearer token Vercel cron sends in `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=

# ───── App URLs / flags ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://membership.amasi.org
# Set to "true" to put the app behind a maintenance banner (no DB writes).
NEXT_PUBLIC_MAINTENANCE_MODE=false
