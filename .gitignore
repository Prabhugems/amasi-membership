# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# .env.example IS committed (template, no secrets). The negation must come
# AFTER `.env*` so it re-includes the file.
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.env*.local

# local dev artifacts (screenshots, agent memory, playwright snapshots)
# Ignore everything inside .claude/ but keep CONTEXT.md tracked — it's the
# version-controlled session-zero brief for Claude Code, used by every dev.
# Note: must use `.claude/*` (not `.claude/`) so git still descends into the
# directory and the negation below can take effect.
.claude/*
!.claude/CONTEXT.md
.playwright-mcp/
/*.png

# Working notes & operational drafts — accumulate applicant PII (names, app
# IDs, payment IDs, narrative of what broke for whom). Have no business in
# git history even on a private repo. Promote to docs/sessions/ or distill
# into CHANGELOG.md / .claude/CONTEXT.md if worth keeping.
#
# Broad pattern catches dated working notes (SESSION-, SECRETARY-BRIEFING-,
# EMAIL-TEMPLATES-, SQL-OPERATIONS-, etc.). Allowlist below for real
# artifacts that happen to match (audits, postmortems, etc.).
*-2026-*.md
!AUDIT-2026-*.md

# test results (generated screenshots, archives, snapshots)
/test-results/
/playwright-report/
/playwright/.auth/

# security: never commit import scripts with hardcoded keys
import_members.js

# Sentry Config File
.env.sentry-build-plugin

# OCR prompt test fixtures (real applicant PII — never commit)
/test-certs/
