{
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "crons": [
    {
      "path": "/api/cron/sla-breach",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/weekly-digest",
      "schedule": "0 4 * * 1"
    },
    {
      "path": "/api/cron/sync-members",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/bulk-draft-reminders",
      "schedule": "30 3 * * *"
    },
    {
      "path": "/api/cron/cleanup-drafts",
      "schedule": "35 3 * * *"
    }
  ]
}
